<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Personal To-Do (Local Save)</title>
  <style>
    :root{
      --bg:#f8fafc; --fg:#0f172a;
      --muted: rgba(15,23,42,.06);
      --muted2: rgba(15,23,42,.10);
      --card: rgba(255,255,255,.88);
      --card2: rgba(255,255,255,.65);
      --border: rgba(15,23,42,.18);
      --primary: rgba(2,132,199,.18);
      --danger: rgba(220,38,38,.10);
      --shadow: 0 6px 18px rgba(2,6,23,.08);
      --radius: 16px;
      --mono: ui-monospace,SFMono-Regular,Menlo,Monaco,Consolas,"Liberation Mono","Courier New",monospace;
      --sans: ui-sans-serif,system-ui,-apple-system,Segoe UI,Roboto,Helvetica,Arial;
    }
    *{box-sizing:border-box}
    body{
      margin:0;
      font-family:var(--sans);
      background:var(--bg);
      color:var(--fg);
      transition: background-color .2s ease, color .2s ease;
    }
    .wrap{max-width:1100px;margin:0 auto;padding:18px}
    .top{display:flex;gap:12px;align-items:flex-end;justify-content:space-between;flex-wrap:wrap;margin-bottom:14px}
    h1{margin:0;font-size:32px;letter-spacing:-.02em}
    .sub{opacity:.72;margin-top:6px;font-size:14px}
    .badges{display:flex;gap:8px;flex-wrap:wrap;align-items:center}
    .badge{font-size:12px;padding:6px 10px;border-radius:999px;border:1px solid var(--border);background:var(--card2)}
    .btn{
      border:1px solid var(--border);
      background:var(--card2);
      color:var(--fg);
      padding:9px 12px;
      border-radius:12px;
      cursor:pointer;
      user-select:none;
      display:inline-flex;gap:8px;align-items:center;
    }
    .btn:hover{background:var(--card)}
    .btn:active{transform:translateY(1px)}
    .btn.primary{background:var(--primary);border-color:rgba(2,132,199,.45)}
    .btn.danger{background:var(--danger);border-color:rgba(220,38,38,.35)}
    .btn:disabled{opacity:.55;cursor:not-allowed}
    .grid{display:grid;grid-template-columns:3fr 2fr;gap:14px}
    @media (max-width:900px){.grid{grid-template-columns:1fr}}
    .card{border:1px solid var(--border);border-radius:var(--radius);background:var(--card);box-shadow:var(--shadow);overflow:hidden}
    .card h2{margin:0;padding:14px 14px 8px;font-size:16px}
    .content{padding:12px 14px 14px}
    label{display:block;font-size:12px;opacity:.75;margin-bottom:6px}
    input[type="text"], input[type="date"], textarea, select{
      width:100%;
      padding:10px;
      border-radius:12px;
      border:1px solid var(--border);
      background:rgba(255,255,255,.55);
      color:var(--fg);
      outline:none;
    }
    textarea{min-height:86px;resize:vertical}
    .controls{display:flex;gap:10px;flex-wrap:wrap;align-items:flex-end}
    .sep{height:1px;background:var(--muted2);margin:12px 0}
    .switchRow{display:flex;justify-content:space-between;align-items:center;padding:10px;border:1px solid var(--border);border-radius:14px;background:var(--card2)}
    .toggle{width:42px;height:24px;border-radius:999px;border:1px solid var(--border);background:rgba(15,23,42,.10);position:relative;cursor:pointer}
    .toggle::after{content:"";position:absolute;top:2px;left:2px;width:18px;height:18px;border-radius:999px;background:var(--card);border:1px solid var(--border);transition:left .15s}
    .toggle.on{background:rgba(2,132,199,.20);border-color:rgba(2,132,199,.45)}
    .toggle.on::after{left:20px}
    .hint{font-size:12px;opacity:.7;margin-top:10px}

    /* Board */
    .board{margin-top:14px}
    .lanes{display:grid;gap:12px;grid-template-columns:repeat(3,1fr)}
    @media (max-width:900px){.lanes{grid-template-columns:1fr}}
    .lane{border:1px solid var(--border);border-radius:var(--radius);background:rgba(15,23,42,.04);overflow:hidden;min-height:180px}
    .laneHeader{display:flex;align-items:center;justify-content:space-between;padding:10px 12px;background:rgba(255,255,255,.30);border-bottom:1px solid var(--muted2)}
    .laneHeader strong{font-size:13px}
    .laneBody{padding:10px}
    .lane.over{outline:2px solid rgba(2,132,199,.65);outline-offset:2px}
    .dropHint{border:1px dashed var(--border);border-radius:14px;padding:14px;text-align:center;font-size:13px;opacity:.75;background:rgba(255,255,255,.18)}
    .task{border:1px solid var(--border);border-radius:14px;background:var(--card);padding:10px;margin-bottom:10px;cursor:grab;user-select:none}
    .task:active{cursor:grabbing}
    .task.dragging{opacity:.6}
    .task.over{outline:2px solid rgba(2,132,199,.65)}
    .taskTitle{font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
    .notes{margin-top:6px;font-size:13px;opacity:.75;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
    .meta{display:flex;gap:8px;flex-wrap:wrap;align-items:center;margin-top:6px}
    .pill{font-size:12px;padding:4px 8px;border-radius:999px;border:1px solid var(--border);background:rgba(255,255,255,.35)}
    .pill.primary{border-color:rgba(2,132,199,.45);background:rgba(2,132,199,.12)}
    .actions{margin-top:10px;display:flex;gap:8px;justify-content:flex-end;flex-wrap:wrap}
    .mini{padding:7px 10px;border-radius:12px;font-size:12px}

    /* Table */
    .tableWrap{margin-top:14px}
    table{width:100%;border-collapse:collapse}
    thead{background:rgba(15,23,42,.05)}
    th,td{padding:10px;border-bottom:1px solid var(--muted2);text-align:left;font-size:13px;vertical-align:top}
    th button{all:unset;cursor:pointer;display:inline-flex;gap:8px;align-items:center;font-weight:600}
    th button:hover{opacity:.9}
    tbody tr:hover{background:rgba(15,23,42,.03)}
    .mono{font-family:var(--mono)}
    .footer{margin-top:14px;font-size:12px;opacity:.7}
    .tableFilters{
      display:grid;
      grid-template-columns: 1fr 140px 180px 180px auto;
      gap:10px;
      align-items:end;
      margin-bottom:10px;
    }
    @media (max-width: 900px){
      .tableFilters{grid-template-columns:1fr 1fr}
    }
    .smallLabel{font-size:12px;opacity:.75;margin-bottom:6px}
  </style>
</head>
<body>
  <div class="wrap">
    <div class="top">
      <div>
        <h1>Personal To-Do</h1>
        <div class="sub">Saved locally in your browser (localStorage). Drag cards to change status and reorder.</div>
      </div>
      <div class="badges">
        <span class="badge" id="bTotal">Total: 0</span>
        <span class="badge" id="bProg">In progress: 0</span>
        <span class="badge" id="bDone">Closed: 0</span>
        <button class="btn" id="btnToggleView" title="Switch view">Table</button>
      </div>
    </div>

    <div class="grid">
      <div class="card">
        <h2 id="composerTitle">Add a task</h2>
        <div class="content">
          <div style="display:flex;justify-content:space-between;gap:10px;align-items:flex-end;flex-wrap:wrap">
            <div style="flex:1;min-width:240px">
              <label>Task</label>
              <input id="inTitle" type="text" placeholder="e.g., Book dentist appointment" />
            </div>
            <div style="display:flex;gap:10px;align-items:flex-end;flex-wrap:wrap">
              <div style="min-width:150px">
                <label>Rank</label>
                <select id="inRank">
                  <option value="1">1 - Highest</option>
                  <option value="2">2</option>
                  <option value="3" selected>3</option>
                  <option value="4">4</option>
                  <option value="5">5 - Lowest</option>
                </select>
              </div>
              <div style="min-width:170px">
                <label>Status</label>
                <select id="inStatus">
                  <option value="todo" selected>To do</option>
                  <option value="in_progress">In progress</option>
                  <option value="done">Closed</option>
                </select>
              </div>
            </div>
          </div>

          <div style="margin-top:10px">
            <label>Notes (optional)</label>
            <textarea id="inNotes" placeholder="Add details, links, next steps..."></textarea>
          </div>

          <div class="controls" style="margin-top:12px">
            <button class="btn primary" id="btnSave">Add task</button>
            <button class="btn" id="btnCancelEdit" style="display:none">Cancel</button>
            <button class="btn danger" id="btnClear">Clear all</button>
          </div>

          <div class="sep"></div>

          <div class="controls">
            <div style="flex:1;min-width:220px">
              <label>Search</label>
              <input id="inSearch" type="text" placeholder="Search tasks..." />
            </div>

            <div style="min-width:190px">
              <label>Lane sort</label>
              <select id="inLaneSort">
                <option value="manual" selected>Manual (lane order)</option>
                <option value="rank">Rank then recent</option>
                <option value="updated">Most recent</option>
              </select>
            </div>

            <div style="min-width:210px">
              <label>Background</label>
              <div style="display:flex;gap:8px;align-items:center">
                <input id="inBg" type="color" value="#f8fafc" style="width:56px;height:38px;padding:3px;border-radius:12px;border:1px solid var(--border);background:transparent" />
                <span class="badge mono" id="bgLabel">#F8FAFC</span>
              </div>
            </div>
          </div>

          <div style="margin-top:10px" class="switchRow">
            <div>
              <div style="font-size:13px;font-weight:600">Hide closed</div>
              <div style="font-size:12px;opacity:.7">Keep completed items out of view</div>
            </div>
            <div class="toggle" id="togHide" aria-label="Hide closed toggle"></div>
          </div>

          <div class="hint">Tip: Click a card to edit. Drag onto another card to insert above it.</div>
        </div>
      </div>

      <div class="card">
        <h2>Quick actions</h2>
        <div class="content">
          <div class="controls">
            <button class="btn" id="btnExport">Export JSON</button>
            <label class="btn" style="cursor:pointer">
              Import JSON
              <input id="fileImport" type="file" accept="application/json" style="display:none" />
            </label>
            <button class="btn" id="btnDemo">Load demo</button>
          </div>
          <div class="sep"></div>
          <div style="font-size:12px;opacity:.7">Local save is per-browser/device. Export a backup if you want to move tasks.</div>
        </div>
      </div>
    </div>

    <div class="board card board" id="boardCard">
      <h2>Board</h2>
      <div class="content">
        <div class="lanes" id="lanes"></div>
      </div>
    </div>

    <div class="tableWrap card" id="tableCard" style="display:none">
      <h2>Table</h2>
      <div class="content">
        <div class="tableFilters">
          <div>
            <div class="smallLabel">Filter: Created (from)</div>
            <input id="tfCreatedFrom" type="date" />
          </div>
          <div>
            <div class="smallLabel">Created (to)</div>
            <input id="tfCreatedTo" type="date" />
          </div>
          <div>
            <div class="smallLabel">Status</div>
            <select id="tfStatus">
              <option value="all" selected>All</option>
              <option value="todo">To do</option>
              <option value="in_progress">In progress</option>
              <option value="done">Closed</option>
            </select>
          </div>
          <div>
            <div class="smallLabel">Rank</div>
            <select id="tfRank">
              <option value="all" selected>All</option>
              <option value="1">1</option>
              <option value="2">2</option>
              <option value="3">3</option>
              <option value="4">4</option>
              <option value="5">5</option>
            </select>
          </div>
          <div style="display:flex;justify-content:flex-end;gap:10px;flex-wrap:wrap">
            <button class="btn" id="btnClearTableFilters">Clear filters</button>
          </div>
        </div>

        <div style="overflow:auto;border:1px solid var(--border);border-radius:14px">
          <table>
            <thead>
              <tr>
                <th><button data-sort="createdAt">Created <span id="sCreatedAt"></span></button></th>
                <th><button data-sort="rank">Rank <span id="sRank"></span></button></th>
                <th><button data-sort="title">Task <span id="sTitle"></span></button></th>
                <th><button data-sort="status">Status <span id="sStatus"></span></button></th>
                <th><button data-sort="updatedAt">Updated <span id="sUpdatedAt"></span></button></th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody id="tbody"></tbody>
          </table>
        </div>
      </div>
    </div>

    <div class="footer">
      LocalStorage keys: <span class="mono">todo_app_html_v1</span>, <span class="mono">todo_bg_html_v1</span>, <span class="mono">todo_ui_html_v1</span>
    </div>
  </div>

<script>
(function(){
  var STORAGE_KEY = "todo_app_html_v1";
  var BG_KEY = "todo_bg_html_v1";

  var Status = { TODO:"todo", IN_PROGRESS:"in_progress", DONE:"done" };
  var STATUS_LABEL = { todo:"To do", in_progress:"In progress", done:"Closed" };

  function $(id){ return document.getElementById(id); }

  var els = {
    bTotal: $("bTotal"), bProg: $("bProg"), bDone: $("bDone"),
    btnToggleView: $("btnToggleView"),
    composerTitle: $("composerTitle"),
    inTitle: $("inTitle"), inNotes: $("inNotes"), inRank: $("inRank"), inStatus: $("inStatus"),
    btnSave: $("btnSave"), btnCancelEdit: $("btnCancelEdit"), btnClear: $("btnClear"),
    inSearch: $("inSearch"), inLaneSort: $("inLaneSort"),
    inBg: $("inBg"), bgLabel: $("bgLabel"),
    togHide: $("togHide"),
    btnExport: $("btnExport"), fileImport: $("fileImport"), btnDemo: $("btnDemo"),
    lanes: $("lanes"),
    boardCard: $("boardCard"), tableCard: $("tableCard"),
    tbody: $("tbody"),
    sCreatedAt:$("sCreatedAt"), sRank:$("sRank"), sTitle:$("sTitle"), sStatus:$("sStatus"), sUpdatedAt:$("sUpdatedAt"),
    tfCreatedFrom:$("tfCreatedFrom"), tfCreatedTo:$("tfCreatedTo"), tfStatus:$("tfStatus"), tfRank:$("tfRank"),
    btnClearTableFilters:$("btnClearTableFilters")
  };

  var state = {
    tasks: [],
    bgColor: "#f8fafc",
    hideClosed: false,
    query: "",
    view: "board",
    laneSort: "manual",
    editingId: null,
    draggingId: null,
    tableSort: { key:"rank", dir:"asc" }, // default by rank
    tableFilters: { createdFrom:"", createdTo:"", status:"all", rank:"all" }
  };

  function uid(){
    return Date.now().toString(36) + "_" + Math.random().toString(36).slice(2,9);
  }
  function clamp(n,min,max){ return Math.min(max, Math.max(min,n)); }
  function safeParse(s, fallback){ try{ var v = JSON.parse(s); return (v == null ? fallback : v); }catch(e){ return fallback; } }

  function normalizeTasks(raw){
    if (!Array.isArray(raw)) return [];
    return raw.map(function(t){
      if (!t || typeof t !== "object") return null;
      var id = (typeof t.id === "string") ? t.id : uid();
      var title = (typeof t.title === "string") ? t.title : "";
      var notes = (typeof t.notes === "string") ? t.notes : "";
      var rank = clamp(Number(t.rank || 3), 1, 5);
      var status = (t.status === Status.TODO || t.status === Status.IN_PROGRESS || t.status === Status.DONE) ? t.status : Status.TODO;
      var createdAt = Number(t.createdAt || Date.now());
      var updatedAt = Number(t.updatedAt || createdAt);
      var order = Number(t.order || 0);
      return { id:id, title:title, notes:notes, rank:rank, status:status, createdAt:createdAt, updatedAt:updatedAt, order:order };
    }).filter(Boolean);
  }

  function lanesInOrder(){ return [Status.TODO, Status.IN_PROGRESS, Status.DONE]; }

  function ensureLaneOrders(tasks){
    var all = normalizeTasks(tasks);
    var rebuilt = [];
    lanesInOrder().forEach(function(lk){
      var laneItems = all.filter(function(t){ return t.status === lk; }).sort(function(a,b){
        var ao = a.order || 0, bo = b.order || 0;
        if (ao > 0 && bo > 0) return ao - bo;
        return (a.updatedAt || 0) - (b.updatedAt || 0);
      });
      laneItems.forEach(function(t,i){
        rebuilt.push(Object.assign({}, t, { order: i+1 }));
      });
    });
    return rebuilt;
  }

  function reorderByLane(prevTasks, dragId, laneKey, beforeTaskId){
    var all = ensureLaneOrders(prevTasks);
    var dragged = all.find(function(t){ return t.id === dragId; });
    if (!dragged) return all;

    var removed = all.filter(function(t){ return t.id !== dragId; });

    var dest = removed.filter(function(t){ return t.status === laneKey; }).sort(function(a,b){ return (a.order||0)-(b.order||0); });
    var patchedDragged = Object.assign({}, dragged, { status: laneKey });

    var insertAt = dest.length;
    if (beforeTaskId){
      var idx = dest.findIndex(function(t){ return t.id === beforeTaskId; });
      if (idx >= 0) insertAt = idx;
    }
    dest.splice(insertAt, 0, patchedDragged);

    var rebuilt = [];
    lanesInOrder().forEach(function(lk){
      var laneItems = (lk === laneKey)
        ? dest
        : removed.filter(function(t){ return t.status === lk; }).sort(function(a,b){ return (a.order||0)-(b.order||0); });
      laneItems.forEach(function(t,i){
        rebuilt.push(Object.assign({}, t, { order: i+1 }));
      });
    });
    return rebuilt;
  }

  function statusOrder(s){ return s === Status.TODO ? 0 : (s === Status.IN_PROGRESS ? 1 : 2); }
  function nextStatus(s){ return s === Status.TODO ? Status.IN_PROGRESS : (s === Status.IN_PROGRESS ? Status.DONE : Status.TODO); }

  function hexToRgb(hex){
    if (typeof hex !== "string") return null;
    var h = hex.trim().replace(/^#/, "");
    var full = (h.length === 3) ? h.split("").map(function(c){ return c+c; }).join("") : h;
    if (full.length !== 6) return null;
    var n = parseInt(full, 16);
    if (Number.isNaN(n)) return null;
    return { r:(n>>16)&255, g:(n>>8)&255, b:n&255 };
  }
  function relLum(rgb){
    var r = rgb.r, g = rgb.g, b = rgb.b;
    var arr = [r,g,b].map(function(v){
      var c = v/255;
      return c <= 0.03928 ? c/12.92 : Math.pow((c+0.055)/1.055, 2.4);
    });
    return 0.2126*arr[0] + 0.7152*arr[1] + 0.0722*arr[2];
  }
  function isDarkHex(hex){
    var rgb = hexToRgb(hex);
    if (!rgb) return false;
    return relLum(rgb) < 0.45;
  }
  function applyTheme(){
    var dark = isDarkHex(state.bgColor);
    document.documentElement.style.setProperty("--bg", state.bgColor);
    document.documentElement.style.setProperty("--fg", dark ? "#F8FAFC" : "#0F172A");

    if (dark){
      document.documentElement.style.setProperty("--muted", "rgba(248,250,252,.08)");
      document.documentElement.style.setProperty("--muted2", "rgba(248,250,252,.14)");
      document.documentElement.style.setProperty("--card", "rgba(15,23,42,.72)");
      document.documentElement.style.setProperty("--card2", "rgba(15,23,42,.46)");
      document.documentElement.style.setProperty("--border", "rgba(248,250,252,.20)");
      document.documentElement.style.setProperty("--shadow", "0 10px 24px rgba(2,6,23,.35)");
    } else {
      document.documentElement.style.setProperty("--muted", "rgba(15,23,42,.06)");
      document.documentElement.style.setProperty("--muted2", "rgba(15,23,42,.10)");
      document.documentElement.style.setProperty("--card", "rgba(255,255,255,.88)");
      document.documentElement.style.setProperty("--card2", "rgba(255,255,255,.65)");
      document.documentElement.style.setProperty("--border", "rgba(15,23,42,.18)");
      document.documentElement.style.setProperty("--shadow", "0 6px 18px rgba(2,6,23,.08)");
    }
  }

  var UI_KEY = "todo_ui_html_v1";

  function save(){
    localStorage.setItem(STORAGE_KEY, JSON.stringify(state.tasks));
    localStorage.setItem(BG_KEY, JSON.stringify(state.bgColor));
    localStorage.setItem(UI_KEY, JSON.stringify({
      hideClosed: state.hideClosed,
      view: state.view,
      laneSort: state.laneSort,
      query: state.query,
      tableSort: state.tableSort,
      tableFilters: state.tableFilters
    }));
  }
  function load(){
    var rawTasks = localStorage.getItem(STORAGE_KEY);
    var rawBg = localStorage.getItem(BG_KEY);
    var rawUi = localStorage.getItem(UI_KEY);
    state.tasks = ensureLaneOrders(normalizeTasks(rawTasks ? safeParse(rawTasks, []) : []));
    state.bgColor = (rawBg ? safeParse(rawBg, "#f8fafc") : "#f8fafc") || "#f8fafc";
    if (rawUi){
      var ui = safeParse(rawUi, {});
      if (typeof ui.hideClosed === "boolean") state.hideClosed = ui.hideClosed;
      if (ui.view === "board" || ui.view === "table") state.view = ui.view;
      if (ui.laneSort) state.laneSort = ui.laneSort;
      if (typeof ui.query === "string") state.query = ui.query;
      if (ui.tableSort && ui.tableSort.key) state.tableSort = ui.tableSort;
      if (ui.tableFilters) state.tableFilters = Object.assign({}, state.tableFilters, ui.tableFilters);
    }
  }

  function escapeHtml(s){
    return String(s).replace(/[&<>"']/g, function(c){
      return ({ "&":"&amp;","<":"&lt;",">":"&gt;","\"":"&quot;","'":"&#039;" })[c];
    });
  }

  function setView(v){
    state.view = v;
    els.boardCard.style.display = (v === "board") ? "" : "none";
    els.tableCard.style.display = (v === "table") ? "" : "none";
    els.btnToggleView.textContent = (v === "board") ? "Table" : "Board";
  }

  function setEditing(task){
    if (!task){
      state.editingId = null;
      els.composerTitle.textContent = "Add a task";
      els.btnSave.textContent = "Add task";
      els.btnCancelEdit.style.display = "none";
      els.inTitle.value = "";
      els.inNotes.value = "";
      els.inRank.value = "3";
      els.inStatus.value = Status.TODO;
      return;
    }
    state.editingId = task.id;
    els.composerTitle.textContent = "Edit task";
    els.btnSave.textContent = "Save changes";
    els.btnCancelEdit.style.display = "";
    els.inTitle.value = task.title;
    els.inNotes.value = task.notes;
    els.inRank.value = String(task.rank);
    els.inStatus.value = task.status;
    try{ els.inTitle.scrollIntoView({ block:"nearest", behavior:"smooth" }); }catch(e){}
  }

  function addOrUpdateFromComposer(){
    var title = (els.inTitle.value || "").trim();
    if (!title) return;

    var notes = (els.inNotes.value || "").trim();
    var rank = clamp(Number(els.inRank.value || 3), 1, 5);
    var status = els.inStatus.value;
    var now = Date.now();

    if (state.editingId){
      var existing = state.tasks.find(function(t){ return t.id === state.editingId; });
      if (!existing){ setEditing(null); return; }

      var statusChanging = status !== existing.status;
      if (statusChanging){
        var destItems = state.tasks.filter(function(t){ return t.status === status && t.id !== existing.id; });
        var maxOrder = destItems.length ? Math.max.apply(null, destItems.map(function(t){ return t.order || 0; })) : 0;
        existing.order = maxOrder + 1;
      }
      existing.title = title;
      existing.notes = notes;
      existing.rank = rank;
      existing.status = status;
      existing.updatedAt = now;

      state.tasks = ensureLaneOrders(state.tasks);
      save(); render();
      setEditing(null);
      return;
    }

    var laneItems = state.tasks.filter(function(t){ return t.status === status; });
    var maxO = laneItems.length ? Math.max.apply(null, laneItems.map(function(t){ return t.order || 0; })) : 0;
    var tnew = { id:uid(), title:title, notes:notes, rank:rank, status:status, order:maxO+1, createdAt:now, updatedAt:now };
    state.tasks = ensureLaneOrders(state.tasks.concat([tnew]));
    save(); render();
    setEditing(null);
  }

  function removeTask(id){
    state.tasks = ensureLaneOrders(state.tasks.filter(function(t){ return t.id !== id; }));
    save(); render();
    if (state.editingId === id) setEditing(null);
  }

  function moveTask(dragId, laneKey, beforeTaskId){
    if (!dragId) return;
    state.tasks = reorderByLane(state.tasks, dragId, laneKey, beforeTaskId || null);
    save(); render();
  }

  function clearAll(){
    if (!confirm("Clear all tasks? This deletes local data on this device.")) return;
    state.tasks = [];
    save(); render();
    setEditing(null);
  }

  function laneComparator(){
    if (state.laneSort === "manual"){
      return function(a,b){ return (a.order||0)-(b.order||0); };
    }
    if (state.laneSort === "rank"){
      return function(a,b){ return (a.rank-b.rank) || ((b.updatedAt||0)-(a.updatedAt||0)); };
    }
    return function(a,b){ return (b.updatedAt||0)-(a.updatedAt||0); };
  }

  function filteredTasks(){
    var q = (state.query || "").trim().toLowerCase();
    return state.tasks.filter(function(t){
      if (state.hideClosed && t.status === Status.DONE) return false;
      if (!q) return true;
      return ((t.title + " " + t.notes).toLowerCase().indexOf(q) !== -1);
    });
  }

  function renderBadges(){
    var total = state.tasks.length;
    var prog = state.tasks.filter(function(t){ return t.status === Status.IN_PROGRESS; }).length;
    var done = state.tasks.filter(function(t){ return t.status === Status.DONE; }).length;
    els.bTotal.textContent = "Total: " + total;
    els.bProg.textContent = "In progress: " + prog;
    els.bDone.textContent = "Closed: " + done;
  }

  function renderBoard(){
    var lanes = [
      { key: Status.TODO, title:"To do" },
      { key: Status.IN_PROGRESS, title:"In progress" },
      { key: Status.DONE, title:"Closed" }
    ];
    var items = filteredTasks();
    var cmp = laneComparator();

    els.lanes.innerHTML = "";

    lanes.forEach(function(lane){
      var laneEl = document.createElement("div");
      laneEl.className = "lane";
      laneEl.dataset.lane = lane.key;

      var laneItems = items.filter(function(t){ return t.status === lane.key; }).slice().sort(cmp);

      laneEl.innerHTML = '<div class="laneHeader"><strong>' + lane.title + '</strong><span class="badge">' + laneItems.length + '</span></div><div class="laneBody"></div>';
      var body = laneEl.querySelector(".laneBody");

      if (!laneItems.length){
        var hint = document.createElement("div");
        hint.className = "dropHint";
        hint.textContent = "Drop tasks here";
        body.appendChild(hint);
      } else {
        laneItems.forEach(function(t){
          var taskEl = document.createElement("div");
          taskEl.className = "task";
          taskEl.draggable = true;
          taskEl.dataset.id = t.id;

          var statusPill = '<span class="pill ' + (t.status === Status.IN_PROGRESS ? 'primary' : '') + '">' + STATUS_LABEL[t.status] + '</span>';
          var rankPill = '<span class="pill">Rank ' + t.rank + '</span>';

          taskEl.innerHTML =
            '<div class="taskTitle">' + escapeHtml(t.title) + '</div>' +
            (t.notes ? '<div class="notes">' + escapeHtml(t.notes) + '</div>' : '') +
            '<div class="meta">' + statusPill + rankPill + '</div>' +
            '<div class="actions">' +
              '<button class="btn mini" data-act="next">Next</button>' +
              '<button class="btn mini danger" data-act="del">Delete</button>' +
            '</div>';

          taskEl.addEventListener("click", function(e){
            var act = e.target && e.target.dataset ? e.target.dataset.act : "";
            if (act) return;
            setEditing(t);
          });

          taskEl.querySelector('[data-act="next"]').addEventListener("click", function(e){
            e.stopPropagation();
            moveTask(t.id, nextStatus(t.status), null);
          });
          taskEl.querySelector('[data-act="del"]').addEventListener("click", function(e){
            e.stopPropagation();
            removeTask(t.id);
          });

          taskEl.addEventListener("dragstart", function(e){
            state.draggingId = t.id;
            taskEl.classList.add("dragging");
            try{ e.dataTransfer.setData("text/plain", t.id); e.dataTransfer.effectAllowed = "move"; }catch(err){}
          });
          taskEl.addEventListener("dragend", function(){
            state.draggingId = null;
            document.querySelectorAll(".lane.over").forEach(function(x){ x.classList.remove("over"); });
            document.querySelectorAll(".task.over").forEach(function(x){ x.classList.remove("over"); });
            taskEl.classList.remove("dragging");
          });

          taskEl.addEventListener("dragover", function(e){
            e.preventDefault(); e.stopPropagation();
            document.querySelectorAll(".task.over").forEach(function(x){ x.classList.remove("over"); });
            taskEl.classList.add("over");
            laneEl.classList.add("over");
            try{ e.dataTransfer.dropEffect = "move"; }catch(err){}
          });

          taskEl.addEventListener("drop", function(e){
            e.preventDefault(); e.stopPropagation();
            var id = "";
            try{ id = e.dataTransfer.getData("text/plain"); }catch(err){ id = state.draggingId; }
            if (id && id !== t.id) moveTask(id, lane.key, t.id); // insert above
          });

          body.appendChild(taskEl);
        });
      }

      laneEl.addEventListener("dragover", function(e){
        e.preventDefault();
        document.querySelectorAll(".lane.over").forEach(function(x){ x.classList.remove("over"); });
        laneEl.classList.add("over");
        try{ e.dataTransfer.dropEffect = "move"; }catch(err){}
      });
      laneEl.addEventListener("dragleave", function(){ laneEl.classList.remove("over"); });
      laneEl.addEventListener("drop", function(e){
        e.preventDefault();
        var id = "";
        try{ id = e.dataTransfer.getData("text/plain"); }catch(err){ id = state.draggingId; }
        if (id) moveTask(id, lane.key, null); // append
      });

      els.lanes.appendChild(laneEl);
    });
  }

  function dateStartOfDayMs(yyyy_mm_dd){
    if (!yyyy_mm_dd) return null;
    var parts = yyyy_mm_dd.split("-");
    if (parts.length !== 3) return null;
    var y = Number(parts[0]), m = Number(parts[1])-1, d = Number(parts[2]);
    var dt = new Date(y, m, d);
    return dt.getTime();
  }

  function applyTableFilters(rows){
    var f = state.tableFilters;

    var fromMs = dateStartOfDayMs(f.createdFrom);
    var toMs = dateStartOfDayMs(f.createdTo);
    // treat "to" as inclusive end-of-day
    if (toMs != null) toMs = toMs + (24*60*60*1000) - 1;

    return rows.filter(function(t){
      if (fromMs != null && (t.createdAt || 0) < fromMs) return false;
      if (toMs != null && (t.createdAt || 0) > toMs) return false;

      if (f.status !== "all" && t.status !== f.status) return false;

      if (f.rank !== "all" && String(t.rank) !== String(f.rank)) return false;

      return true;
    });
  }

  function renderTable(){
    var rows = ensureLaneOrders(state.tasks).slice();
    rows = applyTableFilters(rows);

    var key = state.tableSort.key;
    var dir = state.tableSort.dir;
    var mult = (dir === "asc") ? 1 : -1;

    rows.sort(function(a,b){
      var c = 0;
      if (key === "createdAt") c = (a.createdAt||0) - (b.createdAt||0);
      else if (key === "rank") c = a.rank - b.rank;
      else if (key === "title") c = a.title.localeCompare(b.title);
      else if (key === "status") c = statusOrder(a.status) - statusOrder(b.status);
      else if (key === "updatedAt") c = (a.updatedAt||0) - (b.updatedAt||0);

      if (c !== 0) return c * mult;

      // tie-breakers: rank then created, then updated
      return (a.rank - b.rank) || ((a.createdAt||0)-(b.createdAt||0)) || ((b.updatedAt||0)-(a.updatedAt||0));
    });

    els.tbody.innerHTML = "";
    rows.forEach(function(t){
      var tr = document.createElement("tr");
      tr.innerHTML =
        '<td class="mono" style="opacity:.75">' + new Date(t.createdAt||Date.now()).toLocaleDateString() + '</td>' +
        '<td><span class="pill">Rank ' + t.rank + '</span></td>' +
        '<td><div style="font-weight:600">' + escapeHtml(t.title) + '</div>' +
          (t.notes ? '<div style="font-size:12px;opacity:.7;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:520px">' + escapeHtml(t.notes) + '</div>' : '') +
        '</td>' +
        '<td><span class="pill ' + (t.status===Status.IN_PROGRESS ? 'primary' : '') + '">' + STATUS_LABEL[t.status] + '</span></td>' +
        '<td class="mono" style="opacity:.75">' + new Date(t.updatedAt || t.createdAt).toLocaleString() + '</td>' +
        '<td><div style="display:flex;gap:8px;flex-wrap:wrap">' +
          '<button class="btn mini" data-act="edit">Edit</button>' +
          '<button class="btn mini" data-act="next">Next</button>' +
          '<button class="btn mini danger" data-act="del">Delete</button>' +
        '</div></td>';

      tr.querySelector('[data-act="edit"]').addEventListener("click", function(){ setEditing(t); });
      tr.querySelector('[data-act="next"]').addEventListener("click", function(){ moveTask(t.id, nextStatus(t.status), null); });
      tr.querySelector('[data-act="del"]').addEventListener("click", function(){ removeTask(t.id); });

      els.tbody.appendChild(tr);
    });

    // sort indicators
    var map = { createdAt:els.sCreatedAt, rank:els.sRank, title:els.sTitle, status:els.sStatus, updatedAt:els.sUpdatedAt };
    Object.keys(map).forEach(function(k){ map[k].textContent = ""; });
    map[key].textContent = (dir === "asc") ? "▲" : "▼";
  }

  function render(){
    applyTheme();
    renderBadges();
    renderBoard();
    renderTable();
    els.inBg.value = state.bgColor;
    els.bgLabel.textContent = String(state.bgColor).toUpperCase();
    els.inSearch.value = state.query;
    els.inLaneSort.value = state.laneSort;
    els.togHide.classList.toggle("on", state.hideClosed);
    setView(state.view);

    // reflect table filter inputs
    els.tfCreatedFrom.value = state.tableFilters.createdFrom || "";
    els.tfCreatedTo.value = state.tableFilters.createdTo || "";
    els.tfStatus.value = state.tableFilters.status || "all";
    els.tfRank.value = state.tableFilters.rank || "all";
  }

  // Wire up events
  els.btnToggleView.addEventListener("click", function(){
    state.view = (state.view === "board") ? "table" : "board";
    save();
    setView(state.view);
    renderTable();
  });

  els.btnSave.addEventListener("click", addOrUpdateFromComposer);
  els.btnCancelEdit.addEventListener("click", function(){ setEditing(null); });
  els.btnClear.addEventListener("click", clearAll);

  els.inTitle.addEventListener("keydown", function(e){
    if (e.key === "Enter"){ e.preventDefault(); addOrUpdateFromComposer(); }
  });

  els.inSearch.addEventListener("input", function(e){
    state.query = e.target.value || "";
    save();
    renderBoard();
  });

  els.inLaneSort.addEventListener("change", function(e){
    state.laneSort = e.target.value;
    save();
    renderBoard();
  });

  els.inBg.addEventListener("input", function(e){
    state.bgColor = e.target.value || "#f8fafc";
    save(); render();
  });

  els.togHide.addEventListener("click", function(){
    state.hideClosed = !state.hideClosed;
    save(); renderBoard();
  });

  // Table sort (click headers)
  document.querySelectorAll("thead th button[data-sort]").forEach(function(btn){
    btn.addEventListener("click", function(){
      var k = btn.getAttribute("data-sort");
      if (state.tableSort.key === k){
        state.tableSort.dir = (state.tableSort.dir === "asc") ? "desc" : "asc";
      } else {
        state.tableSort.key = k;
        state.tableSort.dir = "asc";
      }
      save();
      renderTable();
    });
  });

  // Table filters
  function applyTableFilterFromInputs(){
    state.tableFilters.createdFrom = els.tfCreatedFrom.value || "";
    state.tableFilters.createdTo = els.tfCreatedTo.value || "";
    state.tableFilters.status = els.tfStatus.value || "all";
    state.tableFilters.rank = els.tfRank.value || "all";
    save();
    renderTable();
  }
  ["change","input"].forEach(function(evt){
    els.tfCreatedFrom.addEventListener(evt, applyTableFilterFromInputs);
    els.tfCreatedTo.addEventListener(evt, applyTableFilterFromInputs);
  });
  els.tfStatus.addEventListener("change", applyTableFilterFromInputs);
  els.tfRank.addEventListener("change", applyTableFilterFromInputs);

  els.btnClearTableFilters.addEventListener("click", function(){
    state.tableFilters = { createdFrom:"", createdTo:"", status:"all", rank:"all" };
    save();
    render();
  });

  els.btnExport.addEventListener("click", function(){
    var payload = JSON.stringify(ensureLaneOrders(state.tasks), null, 2);
    var stamp = new Date().toISOString().slice(0,10);
    var blob = new Blob([payload], { type:"application/json" });
    var url = URL.createObjectURL(blob);
    var a = document.createElement("a");
    a.href = url;
    a.download = "todo-backup-" + stamp + ".json";
    document.body.appendChild(a);
    a.click();
    a.remove();
    URL.revokeObjectURL(url);
  });

  els.fileImport.addEventListener("change", function(e){
    var file = e.target.files && e.target.files[0];
    if (!file) return;
    file.text().then(function(text){
      var parsed = safeParse(text, null);
      var incoming = normalizeTasks(parsed);
      if (!incoming.length){
        alert("No tasks found in that file.");
        e.target.value = "";
        return;
      }
      var map = new Map(ensureLaneOrders(state.tasks).map(function(t){ return [t.id, t]; }));
      incoming.forEach(function(t){ map.set(t.id, t); });
      state.tasks = ensureLaneOrders(Array.from(map.values()));
      save(); render();
      e.target.value = "";
    });
  });

  els.btnDemo.addEventListener("click", function(){
    if (!confirm("Replace your tasks with demo tasks?")) return;
    var now = Date.now();
    state.tasks = ensureLaneOrders([
      { id:uid(), title:"Plan the week", notes:"Pick 3 priorities and block time.", rank:1, status:Status.TODO, order:1, createdAt:now-172800000, updatedAt:now-172800000 },
      { id:uid(), title:"Write status update", notes:"Keep it short; wins + blockers.", rank:2, status:Status.IN_PROGRESS, order:1, createdAt:now-86400000, updatedAt:now-14400000 },
      { id:uid(), title:"Pay a bill", notes:"Auto-pay if possible.", rank:3, status:Status.DONE, order:1, createdAt:now-259200000, updatedAt:now-600000 }
    ]);
    save(); render();
    setEditing(null);
  });

  // Init
  load();
  render();

  // start bg label from storage
  els.inBg.value = state.bgColor;
  els.bgLabel.textContent = String(state.bgColor).toUpperCase();
})();
</script>
</body>
</html>
